  "repository": "https://github.com/sujitsinghds54970/vaidya-vihar-diagnostic",
  "logo": "https://avatars.githubusercontent.com/u/sujitsinghds54970",
  "keywords": ["erp", "diagnostic", "healthcare", "fastapi", "react"],
  "success_url": "/",
  "env": {
    "SECRET_KEY": {
      "description": "Secret key for JWT token generation",
      "value": "vaidya-vihar-secret-key-2024-change-this-in-production",
