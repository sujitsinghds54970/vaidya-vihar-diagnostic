{
  "name": "vaidya-vihar-diagnostic-erp",
  "version": "2.0.0",
  "description": "Complete Diagnostic Center ERP System with 20+ modules",
  "main": "index.js",
  "scripts": {
    "install-all": "cd backend && pip install -r requirements.txt && cd ../frontend/vaidya-vihar-frontend && npm install",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "start:frontend": "cd frontend/vaidya-vihar-frontend && npm start",
    "build": "cd frontend/vaidya-vihar-frontend && npm run build",
    "init-db": "cd backend && python3 init_database.py",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sujitsinghds54970/vaidya-vihar-diagnostic.git"
  },
  "keywords": [
    "erp",
    "diagnostic",
    "healthcare",
    "laboratory",
    "hospital-management",
    "patient-management",
    "inventory",
    "billing",
    "accounting",
    "hr",
    "lis"
  ],
  "author": "Sujit Singh",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
